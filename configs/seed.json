{
  "seed": {
    "domain": "seed.polyant.top",
    "tls_cert": "/etc/letsencrypt/live/seed.polyant.top/fullchain.pem",
    "tls_key": "/etc/letsencrypt/live/seed.polyant.top/privkey.pem",
    "bootstrap_peers": []
  },
  "node": {
    "type": "seed",
    "name": "polyant-seed-1",
    "data_dir": "./data/seed",
    "log_dir": "./logs",
    "log_level": "info"
  },
  "network": {
    "listen_port": 9000,
    "api_port": 8080,
    "seed_nodes": [],
    "dht_enabled": true,
    "mdns_enabled": false
  },
  "mirror": {
    "enabled": true,
    "categories": ["*"],
    "max_size_gb": 100
  },
  "storage": {
    "kv_type": "pebble",
    "search_type": "bleve"
  },
  "i18n": {
    "default_lang": "zh-CN",
    "available_langs": ["zh-CN", "en-US"],
    "log_bilingual": false
  }
}
